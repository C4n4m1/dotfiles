#    __ ___ __  __
#   / //_(_) /_/ /___ __
#  / ,< / / __/ __/ // /
# /_/|_/_/\__/\__/\_, /

#
# Configuration
# FONT
#
font_family      	family='JetBrainsMono Nerd Font' style=ExtraLight 
bold_font               auto
italic_font      	family='JetBrainsMono Nerd Font' style='ExtraLight Italic' 
#
# font_family      family='IBM Plex Mono'  features=+ss03
# bold_font        auto
# italic_font      auto
# bold_italic_font        family='JetBrainsMono Nerd Font' style='Italic'
font_size        	13.4
# modify_font cell_width      97%


modify_font cell_height 108%
# WINDOW
remember_window_size        no
cursor_blink_interval       0.5
cursor_stop_blinking_after  1
scrollback_lines            2000
wheel_scroll_min_lines      1
enable_audio_bell           no
window_padding_width        10
window_padding_height  	    0
hide_window_decorations     yes
background_opacity          0.8
dynamic_background_opacity  yes
confirm_os_window_close     0
# selection_foreground        none.cache/wal/colors-kitty.conf
selection_background        none
map ctrl+backspace send_text all \x17
# Include theme  colors
include $HOME/.config/kitty/themes/oldworld.conf

# KEYMAPS
map super+u           set_background_opacity 1 
map super+shift+u     set_background_opacity default
map ctrl+shift+p kitten sessionizer/sessionizer.py --project_dir $HOME/projects


#reload config
map ctrl+shift+alt+r  load_config_file  /home/credo/dotfiles/.config/kitty/kitty.conf
# CURSOR
cursor_trail 10
cursor_trail_start_threshold 0
shell_integration no-cursor
cursor_trail_decay 0.01 0.15
cursor_shape block
cursor_blink true

# TABS
map ctrl+shift+tab select_tab
enabled_layouts tall, stack
# tabbar should be at the top
tab_bar_edge top
tab_bar_style powerline
# tab_separator ""
tab_bar_background none
tab_bar_margin_color none
tab_title_template {index}:{title}
# map alt+tab launch --type=background /home/credo/.config/kitty/toggle_tab_bar.sh

# open new split (window) with ctrl+d retaining the cwd
map ctrl+enter new_window_with_cwd
map ctrl+shift+enter new_window

# open new tab with ctrl+t
# map ctrl+t new_tab_with_cwd


# switch between next and previous splits
map alt+tab previous_window
map alt+shift+tab next_window
# map ctrl+h        next_window
# map ctrl+l        previous_window


# jump to beginning and end of line
map alt+left send_text all \x01
map alt+right send_text all \x05

# Map ctrl + <num> to corresponding tabs
map ctrl+& goto_tab 1
map ctrl+é goto_tab 2
map ctrl+" goto_tab 3
map ctrl+' goto_tab 4
map ctrl+( goto_tab 5
map ctrl+- goto_tab 6
map ctrl+è goto_tab 7
map ctrl+_ goto_tab 8
map ctrl+ç goto_tab 9
map ctrl+à goto_tab 10

watcher sessionizer/watcher.py
# REMOTE CONTROL
allow_remote_control yes
